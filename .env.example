# Environment overrides for the Docker Compose stack (compose.yaml).
# Copy to `.env` and fill in the values you want to override. Every variable is
# optional — anything left unset falls back to the values baked into config.yaml
# (created by `docker compose run --rm agent setup`).

# ---- Image / runtime ----
# Override the image tag (e.g. pin a specific release instead of :latest).
# TELETON_IMAGE=ghcr.io/xlabtg/teleton-agent:latest
# Host port to expose the WebUI on.
# TELETON_WEBUI_PORT=7777

# ---- LLM provider ----
# TELETON_API_KEY=sk-ant-...

# ---- Telegram credentials (from https://my.telegram.org/apps) ----
# TELETON_TG_API_ID=12345678
# TELETON_TG_API_HASH=0123456789abcdef
# TELETON_TG_PHONE=+1234567890

# ---- Management API (optional) ----
# TELETON_API_ENABLED=true
# TELETON_API_PORT=7778
